rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'content', 'drawing', 'userId', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 6 &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() <= 100000 &&
             data.title is string && data.title.size() <= 200 &&
             data.drawing is string && data.drawing.size() <= 500000;
    }

    match /notes/{noteId} {
      allow get: if isSignedIn() && isValidId(noteId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && isValidId(noteId) &&
                    isValidNote(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;

      allow update: if isSignedIn() && isValidId(noteId) &&
                    existing().userId == request.auth.uid &&
                    isValidNote(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'drawing', 'updatedAt']);

      allow delete: if isSignedIn() && isValidId(noteId) && existing().userId == request.auth.uid;
    }
  }
}
